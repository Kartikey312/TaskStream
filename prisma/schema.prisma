datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model City {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  users User[]
}

model User {
  id     Int    @id @default(autoincrement())
  name   String
  cityId Int
  city   City   @relation(fields: [cityId], references: [id])
}